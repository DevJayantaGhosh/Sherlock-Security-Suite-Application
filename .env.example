GITHUB_PAT=github_pat_token
VITE_HOST_SERVER_URL=http://localhost:4821

# ── IPFS Backend ─────────────────────────────────────────
# Choose backend: "kubo" (default) or "pinata"
VITE_IPFS_BACKEND=kubo

# ── Kubo (IPFS Desktop) config ───────────────────────────
# Prerequisite: Install & run IPFS Desktop (https://docs.ipfs.tech/install/ipfs-desktop/)
# Local node (default):
VITE_IPFS_RPC_URL=http://127.0.0.1:5001
VITE_IPFS_GATEWAY_URL=http://127.0.0.1:8080
# Remote node — change to the remote machine's IP/hostname:
# VITE_IPFS_RPC_URL=http://192.168.1.100:5001
# VITE_IPFS_GATEWAY_URL=http://192.168.1.100:8080

# ── Pinata Cloud config (used when VITE_IPFS_BACKEND=pinata) ──
# Sign up at https://app.pinata.cloud (free tier = 1 GB)
# VITE_PINATA_JWT=your_pinata_jwt_token_here
# VITE_PINATA_GATEWAY_URL=https://gateway.pinata.cloud

# ── Blockchain (Hedera Testnet) ──────────────────────────
# Contract deployed via Software-Security-Provenance-Chain project
VITE_CONTRACT_ADDRESS=0xYourContractAddressHere

# Hedera Testnet JSON-RPC Relay (HashIO public endpoint)
VITE_HEDERA_RPC_URL=https://testnet.hashio.io/api

# Service account private key (ECDSA hex) — used to sign blockchain transactions
# This account must be added as a serviceAccount on the contract by the owner
VITE_SERVICE_ACCOUNT_PRIVATE_KEY=0xYourPrivateKeyHere